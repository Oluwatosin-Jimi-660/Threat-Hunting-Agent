{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Threat Hunt Agent Telemetry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "envelope", "events"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "endpoint_id", "sent_at", "agent_version", "batch_id", "sequence_num"],
      "properties": {
        "agent_id": {"type": "string"},
        "endpoint_id": {"type": "string"},
        "sent_at": {"type": "string", "format": "date-time"},
        "agent_version": {"type": "string"},
        "batch_id": {"type": "string"},
        "sequence_num": {"type": "integer"}
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "windows_event_id", "log_channel", "recorded_at", "local_score", "data"],
        "properties": {
          "event_id": {"type": "string"},
          "windows_event_id": {"type": "integer"},
          "log_channel": {"type": "string"},
          "recorded_at": {"type": "string", "format": "date-time"},
          "local_score": {"type": "integer", "minimum": 0, "maximum": 100},
          "score_reasons": {"type": "array", "items": {"type": "string"}},
          "data": {"type": "object", "additionalProperties": {"type": "string"}},
          "hashes": {"type": "object", "additionalProperties": {"type": "string"}}
        }
      }
    }
  }
}
